{
  "name": "@precisa-saude/tooling",
  "version": "1.1.0",
  "private": true,
  "description": "Shared tooling, configs, design tokens, and CLI for the precisa-saude ecosystem.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Precisa-Saude/tooling.git"
  },
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "prepare": "husky",
    "release": "semantic-release",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "typecheck": "turbo run typecheck"
  },
  "lint-staged": {
    "*.{ts,mts,cts}": [
      "prettier --write",
      "eslint --fix --max-warnings 0 --no-warn-ignored"
    ],
    "*.{js,cjs,mjs,json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@precisa-saude/commitlint-config": "workspace:*",
    "@precisa-saude/eslint-config": "workspace:*",
    "@precisa-saude/prettier-config": "workspace:*",
    "@precisa-saude/tsconfig": "workspace:*",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.2",
    "prettier-plugin-packagejson": "^3.0.2",
    "semantic-release": "^25.0.3",
    "turbo": "^2.3.7",
    "typescript": "~5.7.3"
  },
  "packageManager": "pnpm@9.15.9+sha512.68046141893c66fad01c079231128e9afb89ef87e2691d69e4d40eee228988295fd4682181bae55b58418c3a253bde65a505ec7c5f9403ece5cc3cd37dcf2531",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9"
  }
}
