pnpm exec commitlint --edit "$1"

# Block AI attribution lines in commit messages
if grep -q -i -E "co-authored-by:.*claude|generated with.*claude|co-authored-by:.*anthropic" "$1"; then
  echo "❌ Commit message contains AI attribution. Remove these lines:"
  grep -i -E "co-authored-by:.*claude|generated with.*claude|co-authored-by:.*anthropic" "$1"
  exit 1
fi
