{
  "name": "@precisa-saude/ui",
  "version": "1.6.0",
  "description": "Shared React components and hooks for Precisa Saúde sites and apps.",
  "keywords": [
    "react",
    "components",
    "hooks",
    "base-ui",
    "tailwind",
    "precisa-saude"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Precisa-Saude/tooling.git",
    "directory": "packages/ui"
  },
  "license": "Apache-2.0",
  "author": "Precisa Saúde",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cards": {
      "types": "./dist/cards/index.d.ts",
      "import": "./dist/cards/index.js"
    },
    "./charts": {
      "types": "./dist/charts/index.d.ts",
      "import": "./dist/charts/index.js"
    },
    "./decorative": {
      "types": "./dist/decorative/index.d.ts",
      "import": "./dist/decorative/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js"
    },
    "./layout": {
      "types": "./dist/layout/index.d.ts",
      "import": "./dist/layout/index.js"
    },
    "./marketing": {
      "types": "./dist/marketing/index.d.ts",
      "import": "./dist/marketing/index.js"
    },
    "./navigation": {
      "types": "./dist/navigation/index.d.ts",
      "import": "./dist/navigation/index.js"
    },
    "./primitives": {
      "types": "./dist/primitives/index.d.ts",
      "import": "./dist/primitives/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist .turbo",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@base-ui/react": "^1.3.0",
    "@precisa-saude/tsconfig": "workspace:*",
    "@types/react": "^19.0.14",
    "@types/react-dom": "^19.0.6",
    "lucide-react": "^0.562.0",
    "react": "^19.0.3",
    "react-dom": "^19.0.3",
    "tsup": "^8.3.5",
    "typescript": "~5.7.3"
  },
  "peerDependencies": {
    "@base-ui/react": "^1.3.0",
    "lucide-react": "^0.400.0 || ^0.500.0 || ^0.600.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.0.0 || ^3.0.0",
    "shiki": "^1.0.0 || ^2.0.0 || ^3.0.0"
  },
  "peerDependenciesMeta": {
    "lucide-react": {
      "optional": true
    },
    "recharts": {
      "optional": true
    },
    "shiki": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
