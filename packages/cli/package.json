{
  "name": "@precisa-saude/cli",
  "version": "1.1.2",
  "description": "Bootstrap and sync Precisa Saúde repositories — the `precisa` CLI.",
  "keywords": [
    "cli",
    "scaffold",
    "bootstrap",
    "precisa-saude"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Precisa-Saude/tooling.git",
    "directory": "packages/cli"
  },
  "license": "Apache-2.0",
  "author": "Precisa Saúde",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "precisa": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && node scripts/copy-templates.mjs",
    "clean": "rm -rf dist .turbo",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "diff": "^7.0.0",
    "ora": "^8.1.1",
    "prompts": "^2.4.2",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@precisa-saude/tsconfig": "workspace:*",
    "@types/diff": "^7.0.0",
    "@types/node": "^22.10.0",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.3.5",
    "typescript": "~5.7.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
