{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Precisa Saúde React",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
